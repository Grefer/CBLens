{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m pytest)",
      "Bash(python3 -c *)",
      "Bash(python -c *)",
      "Bash(python3 -m convertible_bond.*)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Read(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(pip install *)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
